{
    "name": "rakibuddin101/laravel-server-lens",
    "description": "Real-time server observability & traffic monitoring dashboard for Laravel.",
    "keywords": ["laravel", "server", "monitor", "dashboard", "observability", "traffic"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Rakib Uddin",
            "email": "devintime101@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/process": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Rakib\\ServerLens\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rakib\\ServerLens\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rakib\\ServerLens\\ServerLensServiceProvider"
            ],
            "aliases": {
                "ServerLens": "Rakib\\ServerLens\\Facades\\ServerLens"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
